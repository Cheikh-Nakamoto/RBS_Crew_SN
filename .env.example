# ============================================
# RBS Crew SN — Environment Variables
# ============================================
# Copier ce fichier vers .env et renseigner les valeurs :
#   cp .env.example .env

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=rbs
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=rbs_db
DATABASE_URL=postgresql://rbs:change_me_in_production@localhost:5432/rbs_db

# ── Redis ───────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=300

# ── JWT (générer avec: openssl rand -base64 64) ──
# JWT_SECRET sert aussi à dériver la clé de signature du cookie de panier invité.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── API Go ──────────────────────────────────
API_PORT=4000
APP_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Next.js ─────────────────────────────────
# NEXT_PUBLIC_API_URL est un chemin RELATIF : les appels navigateur passent par
# le rewrite Next.js (/backend/* → api-go:4000), ce qui garde tout en même
# origine — indispensable pour le cookie de panier invité.
NEXT_PUBLIC_API_URL=/backend
# URL publique du site. Variable NEXT_PUBLIC_*, donc figée AU BUILD de l'image :
# la changer au runtime n'a aucun effet. Sert aux URLs de retour NabooPay.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:4000
AUTH_URL=http://localhost:3000
AUTH_SECRET=
NODE_ENV=development

# ── NabooPay (moyen de paiement unique en production) ──
NABOO_API_KEY=
NABOO_WEBHOOK_SECRET=
# Laisser vide pour l'URL par défaut du provider.
NABOO_BASE_URL=

# ── Google OAuth (« Continuer avec Google ») ──
# Redirect URI à déclarer dans la console Google Cloud :
#   <APP_URL>/api/auth/callback/google
# L'API Go n'a besoin que du client ID (vérification de l'audience de l'id_token).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (non exposé côté site, conservé pour usage futur) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Autres providers de paiement (implémentés, non branchés au checkout) ──
WAVE_API_KEY=
WAVE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true
# ⚠️ Orange Money : son webhook ne vérifie AUCUNE signature — n'importe qui
# pourrait faire passer une commande en payée. Ne pas mettre à "true" tant que
# payment/orange_money.go n'a pas été corrigé.
ENABLE_ORANGE_MONEY=false
OM_CLIENT_ID=
OM_CLIENT_SECRET=
OM_MERCHANT_KEY=

# ── Mail (SMTP) ─────────────────────────────
# Sans ces variables, aucun e-mail n'est envoyé : vérification d'adresse,
# réinitialisation de mot de passe, invitation artiste, remboursement.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RBS Crew <noreply@rbsakademya.com>"

# ── Cloudflare R2 (stockage média) ──────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=rbs-media
R2_PUBLIC_URL=https://pub-f89062d997054062a74be2228aba1326.r2.dev

# ── Migration WordPress / WooCommerce ───────
# (utilisé uniquement par migration-scripts/, jamais en production)
WP_API_URL=https://rbsakademya.com/wp-json
WC_KEY=ck_...
WC_SECRET=cs_...
