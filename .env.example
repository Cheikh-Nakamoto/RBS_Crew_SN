# ============================================
# RBS Crew SN — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=rbs
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=rbs_db
DATABASE_URL=postgresql://rbs:change_me_in_production@localhost:5432/rbs_db

# ── Redis ───────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=300

# ── JWT (generate with: openssl rand -base64 64) ──
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── NestJS ──────────────────────────────────
API_PORT=4000
NODE_ENV=development

# ── Next.js ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Mail (Nodemailer) ───────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="RBS Crew <noreply@rbsakademya.com>"
FRONTEND_URL=http://localhost:3000

# ── Cloudflare R2 (media storage) ───────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=rbs-media
R2_PUBLIC_URL=https://pub-f89062d997054062a74be2228aba1326.r2.dev

# ── WordPress / WooCommerce Migration ───────
# (used only by migration-scripts/, never in production)
WP_API_URL=https://rbsakademya.com/wp-json
WC_KEY=ck_...
WC_SECRET=cs_...
