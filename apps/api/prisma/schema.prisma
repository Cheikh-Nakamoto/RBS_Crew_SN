generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Locale {
  fr
  en
  de
  es
  it
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
}

enum UserRole {
  CUSTOMER
  ADMIN
  EDITOR
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────
// MEDIA
// ─────────────────────────────────────────────

model Media {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  altText   String?
  wpId      Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productFeatured Product[]      @relation("ProductFeaturedImage")
  productGallery  ProductImage[]
  projectFeatured Project[]      @relation("ProjectFeaturedImage")
  artistFeatured  Artist[]       @relation("ArtistFeaturedImage")
}

// ─────────────────────────────────────────────
// CATEGORIES & TAGS
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  slug      String   @unique
  parentId  String?
  wpId      Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent       Category?              @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]             @relation("CategoryTree")
  products     ProductCategory[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id          String  @id @default(uuid())
  categoryId  String
  locale      Locale
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

model Tag {
  id        String   @id @default(uuid())
  slug      String   @unique
  wpId      Int?     @unique
  createdAt DateTime @default(now())

  translations TagTranslation[]
  products     ProductTag[]
}

model TagTranslation {
  id     String @id @default(uuid())
  tagId  String
  locale Locale
  name   String

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id              String        @id @default(uuid())
  slug            String        @unique
  sku             String?       @unique
  price           Decimal       @db.Decimal(10, 2)
  compareAtPrice  Decimal?      @db.Decimal(10, 2)
  stock           Int           @default(0)
  manageStock     Boolean       @default(true)
  status          ProductStatus @default(DRAFT)
  featuredImageId String?
  wcId            Int?          @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  featuredImage Media?              @relation("ProductFeaturedImage", fields: [featuredImageId], references: [id])
  images        ProductImage[]
  translations  ProductTranslation[]
  categories    ProductCategory[]
  tags          ProductTag[]
  orderItems    OrderItem[]
  attributes    ProductAttribute[]
  variants      ProductVariant[]
}

model ProductTranslation {
  id               String  @id @default(uuid())
  productId        String
  locale           Locale
  name             String
  description      String? @db.Text
  shortDescription String? @db.Text
  slug             String
  metaTitle        String?
  metaDescription  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  mediaId   String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id])

  @@unique([productId, mediaId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model ProductAttribute {
  id        String @id @default(uuid())
  productId String
  name      String
  value     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  sku       String? @unique
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  options   Json
  wcId      Int?    @unique

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// USERS / CUSTOMERS
// ─────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phone           String?
  role            UserRole @default(CUSTOMER)
  emailVerified   Boolean  @default(false)
  preferredLocale Locale   @default(fr)
  wcId            Int?     @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  sessions  UserSession[]
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  label      String?
  firstName  String
  lastName   String
  company    String?
  line1      String
  line2      String?
  city       String
  postalCode String
  country    String  @default("SN")
  isDefault  Boolean @default(false)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersShipping Order[] @relation("ShippingAddress")
  ordersBilling  Order[] @relation("BillingAddress")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                    String        @id @default(uuid())
  orderNumber           String        @unique
  userId                String?
  guestEmail            String?
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(UNPAID)
  stripePaymentIntentId String?       @unique
  currency              String        @default("XOF")
  subtotal              Decimal       @db.Decimal(10, 2)
  taxAmount             Decimal       @db.Decimal(10, 2) @default(0)
  shippingAmount        Decimal       @db.Decimal(10, 2) @default(0)
  discountAmount        Decimal       @db.Decimal(10, 2) @default(0)
  total                 Decimal       @db.Decimal(10, 2)
  shippingAddressId     String?
  billingAddressId      String?
  notes                 String?
  wcId                  Int?          @unique
  locale                Locale        @default(fr)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user            User?     @relation(fields: [userId], references: [id])
  shippingAddress Address?  @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?  @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  variantId   String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  productName String
  productSku  String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// PAGES / CONTENT
// ─────────────────────────────────────────────

model Page {
  id        String        @id @default(uuid())
  slug      String        @unique
  template  String?
  status    ProductStatus @default(DRAFT)
  wpId      Int?          @unique
  parentId  String?
  menuOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  parent       Page?             @relation("PageTree", fields: [parentId], references: [id])
  children     Page[]            @relation("PageTree")
  translations PageTranslation[]
}

model PageTranslation {
  id              String @id @default(uuid())
  pageId          String
  locale          Locale
  title           String
  slug            String
  content         String @db.Text
  excerpt         String?
  metaTitle       String?
  metaDescription String?

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

// ─────────────────────────────────────────────
// SERVICES (Professional portfolio)
// ─────────────────────────────────────────────

model Service {
  id        String        @id @default(uuid())
  slug      String        @unique
  icon      String?
  status    ProductStatus @default(PUBLISHED)
  menuOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  translations ServiceTranslation[]
}

model ServiceTranslation {
  id              String @id @default(uuid())
  serviceId       String
  locale          Locale
  title           String
  description     String @db.Text
  metaTitle       String?
  metaDescription String?

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
}

// ─────────────────────────────────────────────
// PROJECTS (Portfolio)
// ─────────────────────────────────────────────

model Project {
  id              String        @id @default(uuid())
  slug            String        @unique
  featuredImageId String?
  completedAt     DateTime?
  clientName      String?
  status          ProductStatus @default(PUBLISHED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  featuredImage Media?               @relation("ProjectFeaturedImage", fields: [featuredImageId], references: [id])
  translations  ProjectTranslation[]
}

model ProjectTranslation {
  id              String  @id @default(uuid())
  projectId       String
  locale          Locale
  title           String
  summary         String?
  content         String? @db.Text
  metaTitle       String?
  metaDescription String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

// ─────────────────────────────────────────────
// ARTISTS (RBS Crew members)
// ─────────────────────────────────────────────

model Artist {
  id              String        @id @default(uuid())
  slug            String        @unique
  city            String?
  country         String?
  featuredImageId String?
  status          ProductStatus @default(PUBLISHED)
  wpId            Int?          @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  featuredImage Media?              @relation("ArtistFeaturedImage", fields: [featuredImageId], references: [id])
  translations  ArtistTranslation[]
}

model ArtistTranslation {
  id       String  @id @default(uuid())
  artistId String
  locale   Locale
  name     String
  bio      String? @db.Text

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, locale])
  @@index([locale])
}

// ─────────────────────────────────────────────
// FESTIVAL EDITIONS (Last Wall Tour)
// ─────────────────────────────────────────────

model FestivalEdition {
  id            String        @id @default(uuid())
  slug          String        @unique
  editionNumber Int
  year          Int
  city          String?
  country       String        @default("SN")
  status        ProductStatus @default(PUBLISHED)
  wpId          Int?          @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  translations FestivalTranslation[]
}

model FestivalTranslation {
  id                String  @id @default(uuid())
  festivalEditionId String
  locale            Locale
  themeName         String
  summary           String? @db.Text
  content           String? @db.Text

  festivalEdition FestivalEdition @relation(fields: [festivalEditionId], references: [id], onDelete: Cascade)

  @@unique([festivalEditionId, locale])
  @@index([locale])
}

// ─────────────────────────────────────────────
// PRESS MENTIONS (Presse)
// ─────────────────────────────────────────────

model PressMention {
  id        String    @id @default(uuid())
  title     String
  source    String
  sourceUrl String
  logoUrl   String?
  excerpt   String?   @db.Text
  date      DateTime?
  createdAt DateTime  @default(now())
}

// ─────────────────────────────────────────────
// QUOTES (RBS Labz — demandes de devis B2B)
// ─────────────────────────────────────────────

model Quote {
  id           String    @id @default(uuid())
  name         String
  surname      String?
  email        String
  phone        String?
  company      String?
  orderType    String
  quantity     Int?
  deliveryDate DateTime?
  message      String    @db.Text
  status       String    @default("NEW")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
